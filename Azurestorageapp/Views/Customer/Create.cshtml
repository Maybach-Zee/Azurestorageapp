@model Azurestorageapp.Models.CustomerViewModel
@{ ViewData["Title"] = "Add Customer"; }

<h2>➕ Add Customer Profile <small class="text-muted fs-6">(Azure Table Storage)</small></h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                    <input asp-for="FirstName" class="form-control" placeholder="John" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                    <input asp-for="LastName" class="form-control" placeholder="Smith" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="john@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold">Phone</label>
                <input asp-for="Phone" class="form-control" placeholder="+27 71 000 0000" />
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold">Address</label>
                <input asp-for="Address" class="form-control" placeholder="123 Main Street" />
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label fw-semibold">City</label>
                <input asp-for="City" class="form-control" placeholder="Johannesburg" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Save Customer</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="col-md-5 offset-md-1">
        <div class="card bg-light border-0">
            <div class="card-body">
                <h6>ℹ️ What happens when you save?</h6>
                <ol class="small text-muted">
                    <li>Customer profile is stored as a NoSQL entity in <strong>Azure Table Storage</strong>.</li>
                    <li>A registration notification is sent to <strong>Azure Queue Storage</strong>.</li>
                    <li>A log entry is written to <strong>Azure File Share</strong>.</li>
                </ol>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
