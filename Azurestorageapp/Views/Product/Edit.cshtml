@model Azurestorageapp.Models.ProductViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product <small class="text-muted fs-6">(Table Storage + Blob Storage)</small></h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="PartitionKey" />
            <input type="hidden" asp-for="RowKey" />
            <input type="hidden" asp-for="ExistingImageUrl" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Product Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-semibold">Category</label>
                <select asp-for="Category" class="form-select">
                    <option>Electronics</option>
                    <option>Clothing</option>
                    <option>Food & Beverages</option>
                    <option>Home & Garden</option>
                    <option>Sports</option>
                    <option>General</option>
                </select>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="Price" class="form-label fw-semibold">Price (R)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                </div>
                <div class="col-6">
                    <label asp-for="Quantity" class="form-label fw-semibold">Quantity</label>
                    <input asp-for="Quantity" class="form-control" type="number" min="0" />
                </div>
            </div>
            <div class="mb-3">
                @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                {
                    <label class="form-label fw-semibold">Current Image</label>
                    <div class="mb-2">
                        <img src="@Model.ExistingImageUrl" alt="Current" style="width:120px;height:120px;object-fit:cover;" class="rounded border" />
                    </div>
                }
                <label asp-for="ImageFile" class="form-label fw-semibold">
                    Replace Image <span class="text-muted fw-normal">(leave blank to keep existing)</span>
                </label>
                <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Update Product</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
