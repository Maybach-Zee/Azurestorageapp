@model List<Azurestorageapp.Controllers.BlobGalleryItem>
@{
    ViewData["Title"] = "Blob Storage — Image Gallery";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Blob Storage — Image Gallery</h2>
        <p class="text-muted small mb-0">
            All images stored in the <code>product-images</code> Azure Blob container.
            URLs are signed with SAS tokens (valid 1 hour).
        </p>
    </div>
    <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
        + Upload via Product
    </a>
</div>

<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">
        No images in Blob Storage yet.
        <a asp-controller="Product" asp-action="Create">Add a product with an image</a> to populate this gallery.
    </div>
}
else
{
    <!-- Stats bar -->
    <div class="d-flex gap-4 mb-4">
        <div class="text-center">
            <div class="fs-4 fw-bold text-primary">@Model.Count</div>
            <div class="small text-muted">Total Blobs</div>
        </div>
        <div class="text-center">
            <div class="fs-4 fw-bold text-success">@Model.Count(b => b.ProductName != null)</div>
            <div class="small text-muted">Linked to Products</div>
        </div>
        <div class="text-center">
            <div class="fs-4 fw-bold text-warning">@Model.Count(b => b.ProductName == null)</div>
            <div class="small text-muted">Unlinked Blobs</div>
        </div>
    </div>

    <!-- Gallery grid -->
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0">
                    <a href="@item.SasUrl" target="_blank" title="Open full size">
                        <img src="@item.SasUrl"
                             class="card-img-top"
                             style="height:180px; object-fit:cover;"
                             alt="@item.FileName"
                             onerror="this.src=''; this.parentElement.innerHTML='<div class=\'d-flex align-items-center justify-content-center bg-light\' style=\'height:180px\'><span class=\'text-muted small\'>Preview unavailable</span></div>'" />
                    </a>
                    <div class="card-body p-2">
                        @if (item.ProductName != null)
                        {
                            <div class="fw-semibold small text-truncate" title="@item.ProductName">
                                @item.ProductName
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">Unlinked blob</div>
                        }
                        <div class="text-muted" style="font-size:0.7rem; word-break:break-all;"
                             title="@item.FileName">
                            @(item.FileName.Length > 32 ? item.FileName[..32] + "…" : item.FileName)
                        </div>
                    </div>
                    <div class="card-footer p-1 bg-transparent text-center">
                        <a href="@item.SasUrl" target="_blank"
                           class="btn btn-outline-primary btn-sm w-100" style="font-size:0.75rem;">
                            Open Full Size
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 p-3 bg-light rounded border small text-muted">
        <strong>ℹ️ About these URLs:</strong> Images are stored in a <strong>private</strong> Azure Blob container.
        Each link above is a <strong>SAS (Shared Access Signature)</strong> URL — a time-limited signed URL
        that grants read access for 1 hour without making the container public.
        Clicking a link opens the image directly from Azure.
    </div>
}
