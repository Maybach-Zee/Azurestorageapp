@model List<Azurestorageapp.Models.ProductEntity>
@{
    ViewData["Title"] = "Products";
    var orderedKeys = ViewBag.OrderedProductKeys as HashSet<string> ?? new HashSet<string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📦 Products <small class="text-muted fs-6">(Azure Table Storage + Blob Storage)</small></h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Product</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No products yet. <a asp-action="Create">Add your first product.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var hasOrders = orderedKeys.Contains(p.RowKey);
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name"
                                     style="width:55px;height:55px;object-fit:cover;"
                                     class="rounded shadow-sm" />
                            }
                            else
                            {
                                <span class="badge bg-secondary">No image</span>
                            }
                        </td>
                        <td><strong>@p.Name</strong></td>
                        <td><span class="badge bg-primary">@p.Category</span></td>
                        <td class="text-muted small">@p.Description</td>
                        <td>R @p.Price.ToString("0.00")</td>
                        <td>
                            @if (p.Quantity == 0)
                            {
                                <span class="badge bg-danger">Out of stock</span>
                            }
                            else if (p.Quantity <= 5)
                            {
                                <span class="badge bg-warning text-dark">@p.Quantity low</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@p.Quantity</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details"
                               asp-route-partitionKey="@p.PartitionKey"
                               asp-route-rowKey="@p.RowKey"
                               class="btn btn-sm btn-outline-info">View</a>

                            <a asp-action="Edit"
                               asp-route-partitionKey="@p.PartitionKey"
                               asp-route-rowKey="@p.RowKey"
                               class="btn btn-sm btn-outline-warning">Edit</a>

                            @if (hasOrders)
                            {
                                <button class="btn btn-sm btn-outline-danger disabled"
                                        title="Cannot delete — this product has existing orders"
                                        disabled>
                                    🔒 Delete
                                </button>
                            }
                            else
                            {
                                <a asp-action="Delete"
                                   asp-route-partitionKey="@p.PartitionKey"
                                   asp-route-rowKey="@p.RowKey"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (orderedKeys.Any())
    {
        <p class="text-muted small mt-1">
            🔒 Products with existing orders cannot be deleted to preserve order history.
        </p>
    }
}
